# Production Environment Variables Example
# Copy this file to .env and change the values below.

# Production Database URL
# Format: ecto://USER:PASSWORD@HOST/DATABASE
# Note: For host database on Linux/Docker, use: host.docker.internal
DATABASE_URL=ecto://postgres:123456@host.docker.internal/qcommerce_prod

# Secret Key Base for Phoenix session signing/encryption
# Generate a new one using: docker compose run --rm web mix phx.gen.secret
# Or if you have Elixir installed locally: mix phx.gen.secret
SECRET_KEY_BASE=ObYLtl44alkzxbS+KNWiIMwpOBEaVGw63IJWnzrSMhFmyHI4mGiP262xoGd7YInd_change_me

# The production host / domain name where your app is hosted
# For local production testing, you can use: qcommerce.localhost
PHX_HOST=qcommerce.localhost
