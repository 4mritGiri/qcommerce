# =============================================================================
# QCommerce Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# Generate a new secret key:
#   docker compose run --rm web mix phx.gen.secret
#   or: mix phx.gen.secret
# =============================================================================


# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
MIX_ENV=prod

# The domain where your app is hosted
# Prod:  qcom.bizpro.com.np
# Local: qcommerce.localhost
PHX_HOST=qcom.bizpro.com.np

# Traefik routing rule — must match PHX_HOST
# Prod:  Host(`qcom.bizpro.com.np`)
# Local: Host(`qcommerce.localhost`)
HOSTS=Host(`qcom.bizpro.com.np`)

# Port the Phoenix server listens on (default: 4000)
PORT=4000


# -----------------------------------------------------------------------------
# SECRET
# -----------------------------------------------------------------------------
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=REPLACE_WITH_GENERATED_SECRET


# -----------------------------------------------------------------------------
# DATABASE (pick one approach)
# -----------------------------------------------------------------------------

# Option A — full DATABASE_URL (recommended for prod)
# Format: ecto://USER:PASSWORD@HOST/DATABASE
# Use host.docker.internal to reach a DB running on the host machine
DATABASE_URL=ecto://postgres:CHANGE_ME@host.docker.internal/qcommerce_prod

# Option B — individual variables (used in dev compose)
DATABASE_HOST=host.docker.internal
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME
DATABASE_DB=qcommerce_prod
